{
  "$schema": "http://json.schemastore.org/template",
  "author": "Chinthaka Bandara",
  "classifications": ["ASP.NET", "WebAPI"],
  "identity": "Clean.Architecture.Solution",
  "groupIdentity": "Clean.Architecture",
  "name": "Clean Architecture Solution",
  "shortName": "ca-sln",
  "preferNameDirectory": true,
  "sourceName": "CleanArchitectureTemplate",
  "description": "ASP.NET Core Web API using Clean Architecture",

  "symbols": {
    "ProjectName": {
      "type": "parameter",
      "datatype": "string",
      "description": "Name of the project"
    }
  },
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sources": [
    {
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        "**/.vs/**",
        "**/.git/**",
        "**/*.user",
        "**/*.lock.json",
        "**/.DS_Store",
        "**/node_modules/**",
        "**/Template/**",
        "**/packages/**",
        "**/nupkgs/**",
        "README.md",
        "LICENSE",
        "CleanArchitectureTemplate.csproj",
        ".template.config/**"
      ]
    }
  ]
}
